# ============================================
# UPPI — Variaveis de Ambiente
# Copiar para .env.local para desenvolvimento
# ============================================

# SUPABASE (obrigatorio)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# GOOGLE MAPS (obrigatorio)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# FIREBASE FCM — Push Notifications nativas Android (obrigatorio)
FIREBASE_SERVER_KEY=your_firebase_server_key_here

# PARADISE GATEWAY — Pagamentos PIX (obrigatorio)
PARADISE_API_KEY=pk_live_...
PARADISE_API_URL=https://api.paradisepay.com.br

# SMS OTP (opcional)
SMS_API_KEY=
SMS_SENDER_ID=UPPI

# CRON / Webhooks (opcional)
CRON_SECRET=your_cron_secret_here

# CAPACITOR — URL servidor remoto (opcional, so se nao usar build local)
CAPACITOR_SERVER_URL=https://uppi.vercel.app
